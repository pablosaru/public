    {
      "parameters": {
        "jsCode": "const xmlString = $input.item.json.data;\n\n// Parser XML nativo sin librerías\nconst parseValue = (xml, tag) => {\n  const match = xml.match(new RegExp(`<${tag}>(.*?)<\\/${tag}>`, 's'));\n  return match ? match[1].trim() : '';\n};\n\nconst parseAll = (xml, tag) => {\n  const matches = [...xml.matchAll(new RegExp(`<${tag}>(.*?)<\\/${tag}>`, 'gs'))];\n  return matches.map(m => m[1].trim());\n};\n\n// Metadata\nconst domain = parseValue(xmlString, 'domain');\nconst policy = parseValue(xmlString, 'p');\n\nconst dateBegin = parseInt(parseValue(xmlString, 'begin'));\nconst dateEnd = parseInt(parseValue(xmlString, 'end'));\nconst dateFrom = new Date(dateBegin * 1000).toLocaleDateString('es-AR');\nconst dateTo = new Date(dateEnd * 1000).toLocaleDateString('es-AR');\n\n// Records\nconst recordBlocks = [...xmlString.matchAll(/<record>(.*?)<\\/record>/gs)].map(m => m[1]);\n\nconst records = recordBlocks.map(r => ({\n  source_ip: parseValue(r, 'source_ip'),\n  count: parseInt(parseValue(r, 'count')),\n  dkim: parseValue(r, 'dkim'),\n  spf: parseValue(r, 'spf'),\n  envelope_from: parseValue(r, 'envelope_from'),\n  header_from: parseValue(r, 'header_from')\n}));\n\nconst total = records.reduce((acc, r) => acc + r.count, 0);\nconst failures = records.filter(r => r.dkim === 'fail' || r.spf === 'fail');\n\nreturn {\n  json: {\n    domain,\n    policy,\n    date_from: dateFrom,\n    date_to: dateTo,\n    total_emails: total,\n    total_records: records.length,\n    failures_count: failures.length,\n    records,\n    failures\n  }\n};"
      },
