    {
      "name": "Obtener JWT Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Capturar el token de la respuesta (viene como plain text)",
              "const token = pm.response.text().trim();",
              "",
              "if (token && token.length > 10) {",
              "    // Guardar en variable de colección para que esté disponible en todos los requests",
              "    pm.collectionVariables.set('jwt_token', token);",
              "    console.log('✅ Token JWT guardado correctamente.');",
              "    console.log('Token (primeros 50 chars):', token.substring(0, 50) + '...');",
              "",
              "    pm.test('Token obtenido correctamente', function () {",
              "        pm.expect(token).to.not.be.empty;",
              "    });",
              "} else {",
              "    console.log('❌ No se recibió token. Verificá usuario y contraseña.');",
              "    pm.test('Token obtenido correctamente', function () {",
              "        pm.expect.fail('No se recibió token válido.');",
              "    });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "username",
              "value": "{{qualys_username}}",
              "description": "Usuario de Qualys"
            },
            {
              "key": "password",
              "value": "{{qualys_password}}",
              "description": "Contraseña de Qualys"
            },
            {
              "key": "token",
              "value": "true"
            }
          ]
        },
        "url": {
          "raw": "https://{{qualys_gateway}}/auth",
          "protocol": "https",
          "host": [
            "{{qualys_gateway}}"
          ],
          "path": [
            "auth"
          ]
        },
        "description": "Autentica contra el gateway de Qualys y guarda el JWT automáticamente en la variable {{jwt_token}} de la colección."
      },
      "response": []
    },
