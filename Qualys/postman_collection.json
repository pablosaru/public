    {
      "name": "getSolutionByQID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parsear el XML de la respuesta",
              "const responseText = pm.response.text();",
              "",
              "// Extraer el contenido del tag <SOLUTION> con regex",
              "const solutionMatch = responseText.match(/<SOLUTION><!\\[CDATA\\[([\\s\\S]*?)\\]\\]><\\/SOLUTION>/);",
              "",
              "if (solutionMatch && solutionMatch[1]) {",
              "    const solution = solutionMatch[1].trim();",
              "    ",
              "    // Mostrar en la consola de Postman (View > Show Postman Console)",
              "    console.log(\"=== SOLUCIÓN / REMEDIACIÓN ===\");",
              "    console.log(solution);",
              "    ",
              "    // Guardar como variable de entorno para reutilizar",
              "    pm.environment.set(\"vuln_solution\", solution);",
              "    ",
              "    // Mostrar como test visible en la pestaña \"Test Results\"",
              "    pm.test(\"Remediación encontrada\", function () {",
              "        pm.expect(solution).to.not.be.empty;",
              "        console.log(solution);",
              "    });",
              "",
              "} else {",
              "    // Intentar match sin CDATA (algunos QIDs no lo usan)",
              "    const solutionPlain = responseText.match(/<SOLUTION>([\\s\\S]*?)<\\/SOLUTION>/);",
              "    ",
              "    if (solutionPlain && solutionPlain[1]) {",
              "        console.log(\"=== SOLUCIÓN / REMEDIACIÓN ===\");",
              "        console.log(solutionPlain[1].trim());",
              "        pm.environment.set(\"vuln_solution\", solutionPlain[1].trim());",
              "    } else {",
              "        console.log(\"No se encontró el campo SOLUTION en la respuesta.\");",
              "        pm.test(\"SOLUTION no encontrado\", function () {",
              "            pm.expect.fail(\"El QID consultado no tiene campo SOLUTION o hubo un error.\");",
              "        });",
              "    }",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
