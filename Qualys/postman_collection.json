    {
      "name": "getSolutionByCVE-FAIL",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseText = pm.response.text();",
              "",
              "// Extraer todos los bloques <VULN>",
              "const vulnBlocks = responseText.match(/<VULN>[\\s\\S]*?<\\/VULN>/g);",
              "",
              "if (!vulnBlocks) {",
              "    console.log(\"No se encontraron vulnerabilidades para el CVE indicado.\");",
              "} else {",
              "    console.log(`Se encontraron ${vulnBlocks.length} QID(s) asociados al CVE.\\n`);",
              "",
              "    vulnBlocks.forEach((block, index) => {",
              "        const get = (tag) => {",
              "            const m = block.match(new RegExp(`<${tag}><!\\\\[CDATA\\\\[([\\\\s\\\\S]*?)\\\\]\\\\]><\\\\/${tag}>`))",
              "                   || block.match(new RegExp(`<${tag}>([\\\\s\\\\S]*?)<\\\\/${tag}>`));",
              "            return m ? m[1].trim() : \"No disponible\";",
              "        };",
              "",
              "        console.log(`\\n============================`);",
              "        console.log(`QID #${index + 1}: ${get(\"QID\")}`);",
              "        console.log(`TÍTULO:       ${get(\"TITLE\")}`);",
              "        console.log(`CVEs:         ${get(\"CVE_LIST\") || \"Ver respuesta completa\"}`);",
              "        console.log(`SOLUCIÓN:     ${get(\"SOLUTION\")}`);",
              "        console.log(`============================`);",
              "    });",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
