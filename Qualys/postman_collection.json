        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parsear la respuesta XML",
              "const responseXml = pm.response.text();",
              "",
              "// Extraer el ID con regex",
              "const match = responseXml.match(/<id>(\\d+)<\\/id>/);",
              "",
              "if (match && match[1]) {",
              "    const tagId = match[1];",
              "    ",
              "    // Guardarlo como variable de entorno",
              "    pm.environment.set(\"parent_tag_id\", tagId);",
              "    ",
              "    console.log(\"Tag ID guardado: \" + tagId);",
              "    pm.test(\"Tag ID extraído correctamente\", () => pm.expect(tagId).to.not.be.empty);",
              "} else {",
              "    pm.test(\"No se pudo extraer el Tag ID\", () => { throw new Error(\"ID no encontrado en la respuesta\"); });",
              "}"
